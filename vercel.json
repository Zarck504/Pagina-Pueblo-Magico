{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "css/**",
          "js/**",
          "pages/**",
          "*.html",
          "*.jpg",
          "*.jpeg",
          "*.png",
          "*.json",
          "admin-lugares.html"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
